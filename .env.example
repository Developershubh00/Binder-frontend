# Binder ERP Frontend - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Backend API Base URL
# Production: https://binder-backend-0szj.onrender.com/api/
# Development: http://localhost:8000/api/
# Domain: https://erpbinder.com/api/
VITE_API_URL=https://binder-backend-0szj.onrender.com/api/

# Vercel Blob - for image uploads (factory code, artwork, packaging, etc.)
# Get token from Vercel Dashboard → Storage → Blob → Create token (read-write)
# See vercel_blob.md for details
VITE_BLOB_READ_WRITE_TOKEN=

# Google Sheets API (if needed)
# REACT_APP_API_URL=http://localhost:3000
# REACT_APP_SPREADSHEET_ID=your_spreadsheet_id_here
